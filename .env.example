# === Supabase ===
# Создай проект на https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
# Публичный anon-ключ (не используется клиентом напрямую, но пусть будет)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role ключ — СЕКРЕТ, только сервер. Никогда не коммить.
SUPABASE_SERVICE_ROLE_KEY=

# === Вход преподавателя ===
TEACHER_LOGIN=Анастасия
TEACHER_PASSWORD=london

# === Сессия (подписанная cookie) ===
# Сгенерируй: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string

# === Email (Resend) — опционально ===
# Если пусто, email не отправляется, остаются только внутри-сайтовые уведомления.
RESEND_API_KEY=
# От кого отправлять письма (должен быть верифицирован в Resend; для теста подойдёт onboarding@resend.dev)
RESEND_FROM="Расписание <onboarding@resend.dev>"
# Куда слать уведомления преподавателю о новых заявках
TEACHER_EMAIL=

# === App ===
# Базовый URL приложения (для ссылок в письмах и универсальной ссылки)
NEXT_PUBLIC_APP_URL=http://localhost:3000
